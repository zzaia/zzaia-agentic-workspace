{
  "theme": "Default",
  "autoApprove": true,
  "mcpServers": {
    "aspire": {
      "command": "aspire",
      "args": ["agent", "mcp"]
    },
    "headroom": {
      "type": "http",
      "url": "http://mcp-headroom:3008/mcp"
    },
    "bifrost": {
      "type": "http",
      "url": "http://bifrost-server:8080/mcp"
    },
    "mcp-codegraph": {
      "type": "sse",
      "url": "http://mcp-codegraph:8000/api/v1/mcp/sse"
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "bash",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v rtk &>/dev/null; then rtk hook gemini; else cat; fi"
          }
        ]
      }
    ]
  }
}
