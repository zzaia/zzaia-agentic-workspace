{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "{env:ANTHROPIC_BASE_URL}",
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "{env:GOOGLE_GEMINI_BASE_URL}",
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  },
  "mcpServers": {
    "aspire": {
      "type": "local",
      "command": "aspire",
      "args": ["agent", "mcp"]
    },
    "headroom": {
      "type": "remote",
      "url": "http://mcp-headroom:3008/mcp"
    },
    "bifrost": {
      "type": "remote",
      "url": "http://bifrost-server:8080/mcp"
    },
    "mcp-codegraph": {
      "type": "sse",
      "url": "http://mcp-codegraph:8000/api/v1/mcp/sse"
    }
  }
}
