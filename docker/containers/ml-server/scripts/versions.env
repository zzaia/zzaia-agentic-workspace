# ml-server/scripts/versions.env — Version pins for headroom proxy
# These versions are specific to ml-server's venv-system environment

# ── Python version ────────────────────────────────────────────────────────────
export PYTHON_VERSION=3.12

# ── Headroom and web framework ────────────────────────────────────────────────
export HEADROOM_AI_VERSION=0.22.2
export FASTAPI_VERSION=0.136.1
export UVICORN_VERSION=0.47.0

# ── GPU / ML packages (installed when GPU_ENABLED=true) ──────────────────────
export TORCH_VERSION=2.5.1

# ── Miniforge ────────────────────────────────────────────────────────────────
export MINIFORGE_VERSION=26.3.2-2
