#!/bin/bash
# versions.env — Version pins for all workspace tools
# Pinned to specific stable releases to avoid quality drift from "latest" updates.

# ── Language runtimes ──────────────────────────────────────────────────────────
export NODE_VERSION=24
export DOTNET_VERSION=10
export NVM_VERSION=0.40.4
export CONDA_PYTHON_VERSION=3.12

# ── Miniforge ─────────────────────────────────────────────────────────────────
export MINIFORGE_ARCH=x86_64
export MINIFORGE_VERSION=26.3.2-2

# ── CLI tools ─────────────────────────────────────────────────────────────────
export GH_VERSION=2.92.0
export K6_VERSION=2.0.0
export D2_VERSION=0.7.1
export DAPR_VERSION=1.17.1
export RTK_VERSION=0.40.0
export DOCKER_VERSION=28.1.1

# ── npm globals ────────────────────────────────────────────────────────────────
export CLAUDE_CODE_VERSION=2.1.143
export MMDC_VERSION=11.15.0
export CODEX_VERSION=0.131.0
export GEMINI_CLI_VERSION=0.42.0

# ── pip packages ───────────────────────────────────────────────────────────────
export PYPDF_VERSION=6.11.0
export PYTHON_DOCX_VERSION=1.2.0
export TEXTUAL_VERSION=8.2.6
export JINJA2_VERSION=3.1.6
export GRAPHVIZ_VERSION=0.21
export DIAGRAMS_VERSION=0.25.1

# ── Development packages (installed in venv-development via python.sh) ─────────────
export FASTAPI_VERSION=0.136.1
export UVICORN_VERSION=0.47.0
export PYDANTIC_VERSION=2.13.4
export HTTPX_VERSION=0.28.1
export SQLALCHEMY_VERSION=2.0.41
export ALEMBIC_VERSION=1.16.2

# ── GPU / ML packages (installed in venv-analytics when GPU_ENABLED=true) ──────────
export SCIKIT_LEARN_VERSION=1.6.1
