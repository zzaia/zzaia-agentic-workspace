#!/bin/bash
# versions.env — Version pins for all workspace tools
# Empty string = fetch latest from GitHub API or install latest from registry
# Set to a specific version string to pin (e.g. GH_VERSION=2.72.0)

# ── Language runtimes ──────────────────────────────────────────────────────────
export NODE_VERSION=22
export DOTNET_VERSION=10
export NVM_VERSION=0.40.3
export CONDA_PYTHON_VERSION=3.12

# ── Miniforge ─────────────────────────────────────────────────────────────────
export MINIFORGE_ARCH=x86_64
export MINIFORGE_VERSION=latest

# ── CLI tools (empty = resolve latest from GitHub API) ────────────────────────
export GH_VERSION=""
export K6_VERSION=""
export D2_VERSION=""
export DAPR_VERSION=""
export RTK_VERSION=""

# ── npm globals (uses npm dist-tag; "latest" is the npm default) ───────────────
export CLAUDE_CODE_VERSION=latest
export MMDC_VERSION=latest
export CODEX_VERSION=latest
export GEMINI_CLI_VERSION=latest

# ── pip packages (empty = install latest; set to e.g. "3.1.0" to pin) ─────────
export PYPDF_VERSION=""
export PYTHON_DOCX_VERSION=""
export TEXTUAL_VERSION=""
export JINJA2_VERSION=""
export GRAPHVIZ_VERSION=""
export DIAGRAMS_VERSION=""
