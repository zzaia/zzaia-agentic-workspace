# ZZAIA Workspace Docker Compose Configuration
# Non-secret configuration — all secrets are managed via Vault UI after bootstrap
# Secrets are injected at deploy time via BWS_ACCESS_TOKEN to deploy script,
# then managed through Vault UI at http://localhost:${VAULT_PORT:-8200}/ui

# Workspace identity and SSH
WORKSPACE_NAME=my-org
SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# GPU support
GPU_ENABLED=false

# Server profiles (optional): vscode, jupyter, devcontainer, tunnel
DEPLOY_PROFILES=

# Port configuration (optional)
VAULT_PORT=8200
SSH_PORT=2222
VSCODE_PORT=8080
ASPIRE_DASHBOARD_PORT=18890
JUPYTER_PORT=8888
PORTAINER_PORT=9000

# Bitwarden Secrets Manager access token (consumed at deploy time, not persisted)
# Only this secret enters vault-server container; all others retrieved at bootstrap
BWS_ACCESS_TOKEN=
