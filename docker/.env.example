# Required
WORKSPACE_NAME=my-org
SSH_PUBLIC_KEY=ssh-ed25519 AAAA...
VSCODE_PORT=8080
SSH_PORT=2222
ASPIRE_DASHBOARD_PORT=18888

# Sudo password — set to enable sudo access inside the workspace (optional)
ADMIN_PASSWORD=

# Claude Code authentication — alternative to `claude auth login`
ANTHROPIC_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
ANTHROPIC_BEDROCK_BASE_URL=

# Agent CLI authentication (optional — leave empty to disable)
OPENAI_API_KEY=
GEMINI_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=

# MCP integrations (optional — leave empty to disable)
TAVILY_API_KEY=
ADO_MCP_AUTH_TOKEN=
AZURE_DEVOPS_ORGANIZATION=
POSTMAN_API_KEY=
NEW_RELIC_API_KEY=
