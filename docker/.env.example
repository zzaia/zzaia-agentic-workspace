# ════════════════════════════════════════════════════════════════════════════
# ZZAIA Workspace Docker Compose Configuration
# ════════════════════════════════════════════════════════════════════════════

# Required
WORKSPACE_NAME=my-org
SSH_PUBLIC_KEY=ssh-ed25519 AAAA...
GPU_ENABLED=false

# Profiles (optional): vscode, jupyter, devcontainer, tunnel
DEPLOY_PROFILES=

# Port configuration (optional)
VAULT_PORT=8200
SSH_PORT=2222
VSCODE_PORT=8080
ASPIRE_DASHBOARD_PORT=18890
JUPYTER_PORT=8888

# Vault bootstrap
VAULT_ROOT_TOKEN=           # Strong token for Vault initialization

# Bitwarden Secrets Manager (consumed at deploy time, not persisted)
BWS_ACCESS_TOKEN=

# Database and admin credentials
ADMIN_PASSWORD=zzaia1234

# AI/ML Model APIs
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=

# Cloud ML / Bedrock configuration
ANTHROPIC_BEDROCK_BASE_URL=
CLAUDE_CODE_USE_VERTEX=false
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=us-central1
CLAUDE_CODE_USE_FOUNDRY=false
AZURE_FOUNDRY_BASE_URL=

# AWS credentials (optional, for Bedrock/services)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Git integration (required for git-sidecar HTTPS authentication)
# GITHUB_PERSONAL_ACCESS_TOKEN is also used by mcp-github container
# ADO_MCP_AUTH_TOKEN is also used by mcp-azure-devops container
GITHUB_PERSONAL_ACCESS_TOKEN=
ADO_MCP_AUTH_TOKEN=
AZURE_DEVOPS_ORGANIZATION=

# DevOps / API integrations
POSTMAN_API_KEY=
NEW_RELIC_API_KEY=
