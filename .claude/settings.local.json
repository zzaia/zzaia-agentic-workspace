{
  "permissions": {
    "allow": [
      "Bash(git clone:*)",
      "Bash(git worktree:*)",
      "Bash(mkdir:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(tree:*)",
      "Bash(python3:*)",
      "SlashCommand(/websearch:*)",
      "Bash(git --git-dir=.git --work-tree=. config core.bare false)",
      "Bash(git --git-dir=.git remote:*)",
      "Bash(git --git-dir=.git branch:*)"
    ]
  },
  "outputStyle": "agentic-concise",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "document:read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/extract-document.py"
          }
        ]
      }
    ]
  }
}
