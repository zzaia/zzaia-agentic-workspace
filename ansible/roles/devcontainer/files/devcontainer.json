{
  "name": "ZZAIA Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "remoteUser": "vscode",
  "mounts": [
    "source=/opt/tools,target=/opt/tools,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-dotnettools.csharp",
        "ms-vscode.makefile-tools",
        "GitHub.copilot"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8080, 8888],
  "portsAttributes": {
    "8080": {
      "label": "VS Code",
      "onAutoForward": "silent"
    },
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "silent"
    }
  }
}
