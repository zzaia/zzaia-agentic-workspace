{
  "mcpServers": {
    "tavily": {
      "type": "sse",
      "url": "http://mcp-tavily:3001/sse"
    },
    "azure-devops": {
      "type": "sse",
      "url": "http://mcp-azure-devops:3002/sse"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "postman": {
      "type": "sse",
      "url": "http://mcp-postman:3003/sse"
    },
    "aspire": {
      "command": "aspire",
      "args": ["mcp", "start"]
    },
    "new-relic": {
      "type": "sse",
      "url": "http://mcp-newrelic:3004/sse"
    }
  }
}
